@model MHR_V02.Models.Base.Role

@{
    ViewData["Title"] = @ViewData["Delete"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="glass-container  col-md-4">
    <h1 class="glass-heading">@ViewData["Delete"]</h1>
    <h3 class="glass-description">@ViewData["Areyousureyouwanttodeletethis"]</h3>
    <div class="glass-content mt-4">
        <h4>@ViewData["Role"]</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">@ViewData["Name"]</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-2">@ViewData["Description"]</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>

            <dt class="col-sm-2">@ViewData["IsActive"]</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.IsActive)</dd>
        </dl>
    </div>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="@ViewData["Delete"]" class="btn btn-danger glass-btn-danger" />
        <div class="text-center">
            <a asp-action="Index" class="glass-link">@ViewData["BacktoList"]</a>
        </div>
    </form>
</div>
