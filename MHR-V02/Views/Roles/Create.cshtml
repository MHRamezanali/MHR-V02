@model MHR_V02.Models.Base.Role

@{
    ViewData["Title"] = @ViewData["Create"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>@ViewData["Create"]</h1>

<h4>@ViewData["Role"]</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">@ViewData["Name"]</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label">@ViewData["Description"]</label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" />@ViewData["IsActive"]
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value=@ViewData["Create"] class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="text-center">
    <a asp-action="Index" class="glass-link">@ViewData["BacktoList"]</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
