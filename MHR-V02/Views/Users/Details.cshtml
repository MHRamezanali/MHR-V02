@model MHR_V02.ViewModels.Base.UserViewModel

@{
    ViewData["Title"] = @ViewData["UserDetails"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h1 class="text-center text-primary">@ViewData["UserDetails"]</h1>
    <hr />
    <div class="card shadow-sm p-4">
        <div class="card-body">
            <h4 class="card-title">Details of @Model.FirstName @Model.LastName</h4>
            <dl class="row mt-3">
                <dt class="col-sm-3 font-weight-bold">@ViewData["FirstName"]</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.FirstName)</dd>

                <dt class="col-sm-3 font-weight-bold">@ViewData["LastName"]</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.LastName)</dd>

                <dt class="col-sm-3 font-weight-bold">@ViewData["Email"]</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

                <dt class="col-sm-3 font-weight-bold">@ViewData["ActiveStatus"]</dt>
                <dd class="col-sm-9">
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                        @(Model.IsActive ? @ViewData["Active"] : @ViewData["Inactive"])
                    </span>
                </dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">@ViewData["Edit"]</a>
            <a asp-action="Index" class="btn btn-secondary">@ViewData["BacktoList"]</a>
        </div>
    </div>
</div>
